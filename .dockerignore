# Keep the build context small and avoid leaking host-local state into the
# image. Mirrors .gitignore plus a few container-specific exclusions.
node_modules
dist
coverage
.coverage

# Git + editor metadata
.git
.gitignore
.gitattributes
.vscode
.idea
.DS_Store

# Local agent-os runtime + per-user config
.agent-os
.ai-guard
.claude
.cursorrules
.cursorignore
.husky

# Logs and scratch
*.log
docs
evals
scripts/qa

# CI / Docker self-references
.github
Dockerfile
.dockerignore

# Env files (never bake secrets into the image)
.env
.env.*
!.env.example
!.env.sample
